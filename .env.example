# ══════════════════════════════════════════════════════════════════
#  ORACLE-X/N  ·  Environment Configuration
#  Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════════════════

# ── LLM Provider ──────────────────────────────────────────────────
# Choose: "groq" | "openai" | "ollama"
LLM_PROVIDER=groq

# Groq (recommended — fast, free tier available)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# OpenAI (fallback)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Ollama (local, no key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Generation Parameters ──────────────────────────────────────────
LLM_TEMPERATURE=0.75
LLM_MAX_TOKENS=1500

# ── Embeddings ─────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Storage ────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./oracle_xn.db
CHROMA_PERSIST_DIR=./chroma_db
GRAPH_PERSIST_PATH=./oracle_graph.pkl

# ── Nigerian Context ───────────────────────────────────────────────
ENABLE_NIGERIAN_CONTEXT=true
DEFAULT_REGION=Lagos

# ── API ────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
LOG_LEVEL=INFO
